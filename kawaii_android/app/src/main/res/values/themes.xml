<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KawaiiDoodle" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.KawaiiDoodle.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFB7D5</item>
        <item name="postSplashScreenTheme">@style/Theme.KawaiiDoodle</item>
    </style>
</resources>
